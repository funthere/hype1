# ============================================
# HYPE Trading Bot Configuration
# Copy this file to .env and fill in your credentials
# ============================================

# ============================================
# ACCOUNT CREDENTIALS (Required for real trading)
# ============================================
# Your Hyperliquid wallet private key (NEVER commit this to git!)
PRIVATE_KEY=your_private_key_here

# Your Hyperliquid wallet address
ADDRESS=your_wallet_address_here

# Optional: API wallet address for cloud trading
ACCOUNT_ADDRESS=

# ============================================
# TRADING MODE
# ============================================
# Set to "true" for testnet trading (no real money, but real orders)
USE_TESTNET=false

# Set to "true" for paper trading (simulated trades with mainnet data)
PAPER_TRADING=true

# Starting capital for paper trading mode (default: 10000)
PAPER_CAPITAL=10000

# ============================================
# STRATEGY SETTINGS
# ============================================
# Asset to trade
ASSET=HYPE

# Timeframe for trading signals
TIMEFRAME=15m

# Leverage multiplier (1-100)
LEVERAGE=5

# Risk per trade as decimal (0.08 = 8%)
RISK_PER_TRADE_PCT=0.08

# Take profit multiplier (based on ATR)
TP_ATR_MULTIPLIER=2.0

# Stop loss multiplier (based on ATR)
SL_ATR_MULTIPLIER=0.4

# Maximum concurrent positions
MAX_POSITIONS=2

# Maximum trades per day
MAX_DAILY_TRADES=20

# Confidence threshold for signals (0-100)
CONFIDENCE_THRESHOLD=45

# ============================================
# RISK MANAGEMENT
# ============================================
# Maximum daily loss as decimal (0.15 = 15%)
MAX_DAILY_LOSS_PCT=0.15

# Circuit breaker: Stop trading after N consecutive losses
MAX_CONSECUTIVE_LOSSES=3

# Circuit breaker: Cooldown period in minutes
CIRCUIT_BREAKER_COOLDOWN_MINUTES=30

# Enable circuit breaker
CIRCUIT_BREAKER_ENABLED=true

# ============================================
# NOTIFICATIONS (Telegram)
# ============================================
# Enable Telegram notifications
TELEGRAM_ENABLED=false

# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================
# STORAGE
# ============================================
# SQLite database path
DATABASE_PATH=trading_bot.db

# ============================================
# WEB UI / API
# ============================================
# Enable web UI dashboard
WEB_UI_ENABLED=true

# API server host
WEB_UI_HOST=127.0.0.1

# API server port
WEB_UI_PORT=8000

# API URL for dashboard connection
HYPE_BOT_API_URL=http://127.0.0.1:8000

# ============================================
# EMERGENCY
# ============================================
# Emergency shutdown (stops all trading)
EMERGENCY_SHUTDOWN=false
