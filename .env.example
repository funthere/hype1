# Hyperliquid Trading Bot Configuration
# Copy this file to .env and fill in your credentials

# ============================================
# ACCOUNT CREDENTIALS (Required for real trading)
# ============================================
# Your Hyperliquid wallet private key (NEVER commit this to git!)
HYPERLICUID_PRIVATE_KEY=your_private_key_here

# Your Hyperliquid wallet address
HYPERLICUID_ADDRESS=your_wallet_address_here

# ============================================
# TRADING MODE
# ============================================
# Set to "true" for testnet trading (no real money, but real orders)
HYPERLICUID_TESTNET=false

# Set to "true" for paper trading (simulated trades with mainnet data)
HYPERLICUID_PAPER_TRADING=false

# Starting capital for paper trading mode (default: 10000)
HYPERLICUID_PAPER_CAPITAL=10000

# ============================================
# OPTIONAL: DASHBOARD SETTINGS
# ============================================
# API URL for the web dashboard (default: http://127.0.0.1:8000)
HYPE_BOT_API_URL=http://127.0.0.1:8000
